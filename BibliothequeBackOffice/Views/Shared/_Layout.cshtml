@{
    var adminId = Context.Session.GetInt32("AdminId");
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
}

<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Bibliothèque Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

@if (adminId != null)
{
    <aside class="admin-sidebar" id="adminSidebar">

        <div class="sidebar-brand">
            <div class="sidebar-brand-icon">
                <i class="bi bi-book-half"></i>
            </div>
            <div class="sidebar-brand-text">
                <span class="brand-name">BiblioAdmin</span>
                <span class="brand-sub">Back Office</span>
            </div>
        </div>

        <!-- Navigation -->
        <nav class="sidebar-nav">
            <div class="nav-section-label">Navigation</div>

            <a class="sidebar-link @(currentController == "Livre" ? "active" : "")"
               asp-controller="Livre" asp-action="Index">
                <i class="bi bi-book"></i>
                <span>Livres</span>
            </a>

            <a class="sidebar-link @(currentController == "Utilisateur" ? "active" : "")"
               asp-controller="Utilisateur" asp-action="Index">
                <i class="bi bi-people"></i>
                <span>Utilisateurs</span>
            </a>

            <a class="sidebar-link @(currentController == "Abonnement" ? "active" : "")"
               asp-controller="Abonnement" asp-action="Index">
                <i class="bi bi-credit-card-2-front"></i>
                <span>Abonnements</span>
            </a>

            <a class="sidebar-link @(currentController == "Lecture" ? "active" : "")"
               asp-controller="Lecture" asp-action="Index">
                <i class="bi bi-journal-bookmark"></i>
                <span>Lectures</span>
            </a>

            <div class="nav-section-label mt-3">Compte</div>

            <a class="sidebar-link sidebar-link--danger"
               asp-controller="Admin" asp-action="Logout">
                <i class="bi bi-box-arrow-left"></i>
                <span>Déconnexion</span>
            </a>
        </nav>

        <!-- Footer sidebar -->
        <div class="sidebar-footer">
            <div class="admin-badge">
                <i class="bi bi-shield-check"></i>
                <span>Administrateur</span>
            </div>
        </div>
    </aside>

    <!-- Overlay mobile -->
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>

    <!-- ══════════════════════════════════════════
         CONTENU PRINCIPAL
    ══════════════════════════════════════════ -->
    <div class="admin-main">

        <!-- Top Bar -->
        <header class="admin-topbar">
            <div class="topbar-left">
                <button class="sidebar-toggle" onclick="toggleSidebar()" aria-label="Toggle sidebar">
                    <i class="bi bi-list"></i>
                </button>
                <div class="page-breadcrumb">
                    <span class="breadcrumb-section">@(currentController ?? "Accueil")</span>
                    <i class="bi bi-chevron-right"></i>
                    <span class="breadcrumb-page">@(ViewData["Title"] ?? "Index")</span>
                </div>
            </div>
            <div class="topbar-right">
                <div class="topbar-time" id="topbarTime"></div>
                <div class="topbar-admin">
                    <div class="admin-avatar">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <span>Admin</span>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="admin-content">
            @RenderBody()
        </main>

    </div>
}
else
{
    <!-- ══════════════════════════════════════════
         MODE NON CONNECTÉ (Login page)
    ══════════════════════════════════════════ -->
    <div class="auth-wrapper">
        <main class="auth-content">
            @RenderBody()
        </main>
    </div>
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    // Sidebar toggle (mobile)
    function toggleSidebar() {
        const sidebar = document.getElementById('adminSidebar');
        const overlay = document.getElementById('sidebarOverlay');
        sidebar.classList.toggle('open');
        overlay.classList.toggle('show');
    }

    // Horloge topbar
    function updateTime() {
        const el = document.getElementById('topbarTime');
        if (!el) return;
        const now = new Date();
        el.textContent = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit' });
    }
    updateTime();
    setInterval(updateTime, 60000);
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
