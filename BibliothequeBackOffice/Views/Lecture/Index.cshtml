@using LibraryBackOffice.Models
@using System.Configuration
@model PageResults<HistoriqueLecture>

@{
    ViewData["Title"] = "Lectures";
    var moisQuery  = Context.Request.Query["mois"].ToString();
    var anneeQuery = Context.Request.Query["annee"].ToString();
    bool filtreActif = !string.IsNullOrEmpty(moisQuery) && !string.IsNullOrEmpty(anneeQuery);
}
<div class="page-header">
    <div>
        <h1><i class="bi bi-credit-card-2-front me-2 text-accent"></i>Historique de lectures</h1>
        <p class="page-subtitle">
            @Model.TotalItems lecture(s) ·
            @if (filtreActif)
            {
                <span>Filtre : mois <strong>@moisQuery</strong> / <strong>@anneeQuery</strong></span>
            }
            else
            {
                <span>Toutes les périodes</span>
            }
        </p>
    </div>
</div>

<div class="admin-panel mb-4">
    <div class="admin-panel-header">
        <div class="admin-panel-title">
            <i class="bi bi-funnel"></i> Filtrer par période
        </div>
    </div>
    <div class="admin-panel-body">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label">Mois</label>
                    <select name="mois" class="form-select">
                        <option value="">— Tous les mois —</option>
                        @{
                            var moisNoms = new[]{"Janvier","Février","Mars","Avril","Mai","Juin",
                                                 "Juillet","Août","Septembre","Octobre","Novembre","Décembre"};
                        }
                        @for (int m = 1; m <= 12; m++)
                        {
                            var isSelected = moisQuery == m.ToString();
                            <option value="@m" selected="@isSelected">
                                @moisNoms[m - 1]
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Année</label>
                    <input type="number"
                           class="form-control"
                           name="annee"
                           value="@anneeQuery"
                           placeholder="ex. 2025"
                           min="2000" max="2099">
                </div>
                <div class="col-md-auto">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Filtrer
                    </button>
                    @if (filtreActif)
                    {
                        <a asp-action="Index" class="btn btn-secondary ms-2">
                            <i class="bi bi-x-lg"></i> Réinitialiser
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="admin-panel">
    <div class="admin-panel-header">
        <div class="admin-panel-title">
            <i class="bi bi-table"></i> Listes des lectures
        </div>
        <span class="text-muted-sm">@Model.Items.Count() entrée(s) sur cette page</span>
    </div>

    <div class="table-responsive">
        <table class="admin-table w-100">
            <thead>
                <tr>
                    <th><i class="bi bi-calendar-check me-1"></i>Date de lecture</th>
                    <th><i class="bi bi-book me-1"></i>Titre du livre</th>
                    <th><i class="bi bi-person me-1"></i>Utilisateur</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="3" class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size:2rem; color:var(--text-muted);"></i>
                            <p class="text-muted-sm mt-2">Aucune lecture trouvée.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Date_Lecture!.Value.ToString("dd/MM/yyyy")</td>
                            <td>@Html.DisplayFor(modelItem => item.Livre!.Titre)</td>
                            <td>@item.Utilisateur!.Nom @item.Utilisateur.Prenom</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if(Model.TotalPages > 1) {
        <div class="admin-pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link btn btn-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-mois="@Context.Request.Query["mois"]"
                       asp-route-annee="@Context.Request.Query["annee"]">
                        &lt;&lt;
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link btn btn-secondary"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-mois="@Context.Request.Query["mois"]"
                           asp-route-annee="@Context.Request.Query["annee"]">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link btn btn-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-mois="@Context.Request.Query["mois"]"
                       asp-route-annee="@Context.Request.Query["annee"]">
                        &gt;&gt;
                    </a>
                </li>
            </ul>
        </div>
    }
</div>