@model LibraryBackOffice.Models.Admin

@{
    ViewData["Title"] = "Détails de l'administrateur";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-eye me-2 text-accent"></i>Détails de l'administrateur</h1>
        <p class="page-subtitle">@Model.Prenom @Model.Nom — #@Model.Id</p>
    </div>
    <div class="d-flex gap-2">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">
            <i class="bi bi-pencil"></i> Modifier
        </a>
        <a asp-action="List" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <!-- Avatar card -->
        <div class="admin-panel mb-4">
            <div class="admin-panel-body">
                <div class="d-flex align-items-center gap-4">
                    <div style="width:64px;height:64px;border-radius:50%;background:linear-gradient(135deg,var(--accent-start),var(--accent-end));display:flex;align-items:center;justify-content:center;color:#fff;font-size:1.4rem;font-weight:700;flex-shrink:0;">
                        @Model.Prenom.Substring(0,1).ToUpper()@Model.Nom.Substring(0,1).ToUpper()
                    </div>
                    <div>
                        <div style="font-size:1.2rem;font-weight:700;color:var(--text-primary);">@Model.Prenom @Model.Nom</div>
                        <div class="text-muted-sm">@@Model.Username</div>
                        <div class="mt-2">
                            @if (Model.Active)
                            {
                                <span class="badge-status active"><i class="bi bi-check-circle-fill"></i> Compte actif</span>
                            }
                            else
                            {
                                <span class="badge-status expired"><i class="bi bi-x-circle-fill"></i> Compte inactif</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Détail -->
        <div class="admin-panel">
            <div class="admin-panel-header">
                <div class="admin-panel-title">
                    <i class="bi bi-shield-lock"></i> Informations du compte
                </div>
            </div>
            <div class="admin-panel-body p-0">
                <table class="w-100" style="border-collapse:collapse;">
                    <tbody>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-hash me-2 text-accent"></i>ID</td>
                            <td class="detail-value">#@Model.Id</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-person me-2 text-accent"></i>Prénom</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Prenom)</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-person me-2 text-accent"></i>Nom</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Nom)</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-at me-2 text-accent"></i>Nom d'utilisateur</td>
                            <td class="detail-value">
                                <code style="background:#f4f6fb;padding:3px 8px;border-radius:6px;font-size:.82rem;color:var(--accent);">
                                    @Html.DisplayFor(m => m.Username)
                                </code>
                            </td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-lock me-2 text-accent"></i>Mot de passe</td>
                            <td class="detail-value">
                                <span style="letter-spacing:3px;color:var(--text-muted);">••••••••</span>
                            </td>
                        </tr>
                        <tr class="detail-row" style="border-bottom:none;">
                            <td class="detail-label"><i class="bi bi-toggle-on me-2 text-accent"></i>Statut</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Active)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</div>

<style>
.detail-row td { padding: 13px 22px; border-bottom: 1px solid #f1f3f7; font-size:.875rem; }
.detail-label  { width: 200px; color: var(--text-secondary); font-weight: 600; background: #fafbfc; }
.detail-value  { color: var(--text-primary); font-weight: 500; }
</style>
