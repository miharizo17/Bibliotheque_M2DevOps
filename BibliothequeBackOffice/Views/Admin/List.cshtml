@model IEnumerable<LibraryBackOffice.Models.Admin>

@{
    ViewData["Title"] = "Administrateurs";
}

<!-- ══ EN-TÊTE ══ -->
<div class="page-header">
    <div>
        <h1><i class="bi bi-shield-lock me-2 text-accent"></i>Administrateurs</h1>
        <p class="page-subtitle">@Model.Count() compte(s) administrateur enregistré(s)</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvel administrateur
    </a>
</div>

<!-- ══ TABLEAU ══ -->
<div class="admin-panel">
    <div class="admin-panel-header">
        <div class="admin-panel-title">
            <i class="bi bi-people"></i> Liste des comptes
        </div>
    </div>

    <div class="table-responsive">
        <table class="admin-table w-100">
            <thead>
                <tr>
                    <th>Administrateur</th>
                    <th><i class="bi bi-person-badge me-1"></i>Nom d'utilisateur</th>
                    <th>Statut</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="4" class="text-center py-5">
                            <i class="bi bi-person-x" style="font-size:2rem;color:var(--text-muted);"></i>
                            <p class="text-muted-sm mt-2">Aucun administrateur trouvé.</p>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div class="d-flex align-items-center gap-3">
                                    <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,var(--accent-start),var(--accent-end));display:flex;align-items:center;justify-content:center;color:#fff;font-size:.85rem;font-weight:700;flex-shrink:0;">
                                        @item.Prenom.Substring(0,1).ToUpper()@item.Nom.Substring(0,1).ToUpper()
                                    </div>
                                    <div>
                                        <div style="font-weight:600;color:var(--text-primary);">@item.Prenom @item.Nom</div>
                                        <div class="text-muted-sm">Administrateur</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <code style="background:#f4f6fb;padding:3px 8px;border-radius:6px;font-size:.82rem;color:var(--accent);">
                                    @Html.DisplayFor(m => item.Username)
                                </code>
                            </td>
                            <td>
                                @if (item.Active)
                                {
                                    <span class="badge-status active">
                                        <i class="bi bi-check-circle-fill"></i> Actif
                                    </span>
                                }
                                else
                                {
                                    <span class="badge-status expired">
                                        <i class="bi bi-x-circle-fill"></i> Inactif
                                    </span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.Id"
                                       class="btn btn-icon btn-secondary" title="Voir les détails">
                                        <i class="bi bi-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.Id"
                                       class="btn btn-icon btn-primary" title="Modifier">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.Id"
                                       class="btn btn-icon btn-danger" title="Supprimer">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
