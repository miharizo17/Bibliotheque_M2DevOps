@model LibraryBackOffice.Models.HistoriqueAbonnement

@{
    ViewData["Title"] = "Nouvel abonnement";
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-plus-circle me-2 text-accent"></i>Nouvel abonnement</h1>
        <p class="page-subtitle">Enregistrer un nouvel historique d'abonnement</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour à la liste
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">
        <div class="admin-panel">
            <div class="admin-panel-header">
                <div class="admin-panel-title">
                    <i class="bi bi-credit-card-2-front"></i>
                    Informations de l'abonnement
                </div>
            </div>
            <div class="admin-panel-body">

                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2 mb-4" role="alert"></div>

                    <div class="row g-4">

                        <div class="col-md-6">
                            <label asp-for="Date_Paiement" class="form-label">
                                <i class="bi bi-calendar-check me-1 text-accent"></i>
                                Date de paiement
                            </label>
                            <input asp-for="Date_Paiement" class="form-control" type="date" />
                            <span asp-validation-for="Date_Paiement" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Date_Expiration" class="form-label">
                                <i class="bi bi-calendar-x me-1 text-accent"></i>
                                Date d'expiration
                            </label>
                            <input asp-for="Date_Expiration" class="form-control" type="date" />
                            <span asp-validation-for="Date_Expiration" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Id_TypeAbonnement" class="form-label">
                                <i class="bi bi-tag me-1 text-accent"></i>
                                Type d'abonnement
                            </label>
                            <input asp-for="Id_TypeAbonnement" class="form-control" placeholder="ID du type" />
                            <span asp-validation-for="Id_TypeAbonnement" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="Id_ModePaiement" class="form-label">
                                <i class="bi bi-wallet2 me-1 text-accent"></i>
                                Mode de paiement
                            </label>
                            <input asp-for="Id_ModePaiement" class="form-control" placeholder="ID du mode" />
                            <span asp-validation-for="Id_ModePaiement" class="text-danger small"></span>
                        </div>

                        <div class="col-12">
                            <label asp-for="Id_Utilisateur" class="form-label">
                                <i class="bi bi-person me-1 text-accent"></i>
                                Utilisateur (client)
                            </label>
                            <input asp-for="Id_Utilisateur" class="form-control" placeholder="ID de l'utilisateur" />
                            <span asp-validation-for="Id_Utilisateur" class="text-danger small"></span>
                        </div>

                    </div>

                    <div class="divider"></div>

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-x-lg"></i> Annuler
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Enregistrer
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
