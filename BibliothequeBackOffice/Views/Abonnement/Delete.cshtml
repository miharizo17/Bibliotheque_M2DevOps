@model LibraryBackOffice.Models.HistoriqueAbonnement

@{
    ViewData["Title"] = "Supprimer l'abonnement";
}

<!-- ══ EN-TÊTE ══ -->
<div class="page-header">
    <div>
        <h1><i class="bi bi-trash me-2" style="color:var(--danger);"></i>Supprimer l'abonnement</h1>
        <p class="page-subtitle">Abonnement #@Model.Id</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6 col-md-8">

        <!-- Avertissement -->
        <div class="admin-panel mb-4" style="border: 1.5px solid rgba(239,68,68,0.3);">
            <div class="admin-panel-header" style="background: rgba(239,68,68,0.06);">
                <div class="admin-panel-title" style="color: var(--danger);">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Confirmation de suppression
                </div>
            </div>
            <div class="admin-panel-body">
                <p style="color: var(--text-secondary); font-size:.9rem; margin-bottom:0;">
                    Vous êtes sur le point de supprimer définitivement cet abonnement.
                    Cette action est <strong>irréversible</strong>.
                </p>
            </div>
        </div>

        <!-- Récapitulatif -->
        <div class="admin-panel mb-4">
            <div class="admin-panel-header">
                <div class="admin-panel-title">
                    <i class="bi bi-credit-card-2-front"></i>
                    Abonnement à supprimer
                </div>
            </div>
            <div class="admin-panel-body p-0">
                <table class="w-100" style="border-collapse:collapse;">
                    <tbody>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-calendar-check me-2 text-accent"></i>Date de paiement</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Date_Paiement)</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-calendar-x me-2 text-accent"></i>Date d'expiration</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Date_Expiration)</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-tag me-2 text-accent"></i>Type</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Id_TypeAbonnement)</td>
                        </tr>
                        <tr class="detail-row">
                            <td class="detail-label"><i class="bi bi-wallet2 me-2 text-accent"></i>Mode de paiement</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Id_ModePaiement)</td>
                        </tr>
                        <tr class="detail-row" style="border-bottom:none;">
                            <td class="detail-label"><i class="bi bi-person me-2 text-accent"></i>Utilisateur</td>
                            <td class="detail-value">@Html.DisplayFor(m => m.Id_Utilisateur)</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Actions -->
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Annuler
                </a>
                <button type="submit" class="btn btn-danger"
                        style="background:var(--danger); border:none; color:#fff; box-shadow:0 4px 14px rgba(239,68,68,.35);">
                    <i class="bi bi-trash-fill"></i> Confirmer la suppression
                </button>
            </div>
        </form>

    </div>
</div>

<style>
.detail-row td { padding: 13px 22px; border-bottom: 1px solid #f1f3f7; font-size:.875rem; }
.detail-label  { width: 200px; color: var(--text-secondary); font-weight: 600; background: #fafbfc; }
.detail-value  { color: var(--text-primary); font-weight: 500; }
</style>
