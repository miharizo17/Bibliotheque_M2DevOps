@using LibraryBackOffice.Models
@model PageResults<LibraryBackOffice.Models.Utilisateur>

@{
    ViewData["Title"] = "Utilisateurs";
    var searchQuery = Context.Request.Query["search"].ToString();
    var searchActif = !string.IsNullOrEmpty(searchQuery);
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-credit-card-2-front me-2 text-accent"></i>utilisateurs inscrits</h1>
        <p class="page-subtitle">
            @Model.TotalItems utilisateur(s)·
        </p>
    </div>
</div>

<div class="admin-panel mb-4">
    <div class="admin-panel-header">
        <div class="admin-panel-title">
            <i class="bi bi-funnel"></i> Rechercher un utilisateur
        </div>
    </div>
    <div class="admin-panel-body">
        <form method="get">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">Nom, prénom, mail ou téléphone</label>
                    <input type="text"
                           class="form-control"
                           name="search"
                           value="@Context.Request.Query["search"]"
                           placeholder="ex. Dupont">
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-search me-2"></i> Rechercher
                    </button>
                    @if (searchActif)
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">
                            <i class="bi bi-x-circle me-2"></i> Réinitialiser
                        </a>
                    }
                </div>
            </div>
        </form>
    </div>
</div>

<div class="admin-panel">
    <div class="admin-panel-header">
        <div class="admin-panel-title">
            <i class="bi bi-table"></i> Listes des utilisateurs
        </div>
        <span class="text-muted-sm">@Model.Items.Count() entrée(s) sur cette page</span>
    </div>

    <div class="table-responsive">
        <table class="admin-table w-100">
            <thead>
                <tr>
                    <th>Inscription</th>
                    <th>Nom</th>
                    <th>Prenom</th>
                    <th>Téléphone</th>
                    <th>Mail</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <i class="bi bi-inbox" style="font-size:2rem; color:var(--text-muted);"></i>
                            <p class="text-muted-sm mt-2">Aucun utilisateur trouvé.</p>
                        </td>
                    </tr>
                } else {
                    @foreach (var item in Model.Items) {
                        <tr>
                            <td>@item.DateEntree!.Value.ToString("dd/MM/yyyy")</td>
                            <td>@Html.DisplayFor(modelItem => item.Nom)</td>
                            <td>@Html.DisplayFor(modelItem => item.Prenom)</td>
                            <td>@Html.DisplayFor(modelItem => item.Telephone)</td>
                            <td>@Html.DisplayFor(modelItem => item.Mail)</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if(Model.TotalPages > 1) {
        <div class="admin-pagination">
            <ul class="pagination justify-content-center">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link btn btn-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page - 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-search="@Context.Request.Query["search"]">
                        &lt;&lt;
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link btn btn-secondary"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-pageSize="@Model.PageSize"
                           asp-route-search="@Context.Request.Query["search"]">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(Model.Page == Model.TotalPages ? "disabled" : "")">
                    <a class="page-link btn btn-secondary"
                       asp-action="Index"
                       asp-route-page="@(Model.Page + 1)"
                       asp-route-pageSize="@Model.PageSize"
                       asp-route-search="@Context.Request.Query["search"]">
                        &gt;&gt;
                    </a>
                </li>
            </ul>
        </div>
    }
</div>