@model LibraryBackOffice.Models.Livre

@{
    ViewData["Title"] = "Retirer le livre";
    string typeLivreText = "";
    var typeLivreList = ViewBag.TypeLivreList as SelectList;
    if (typeLivreList != null)
    {
        var found = typeLivreList.FirstOrDefault(x => x.Value == Model.Id_TypeLivre.ToString());
        if (found != null) typeLivreText = found.Text;
    }
}

<div class="page-header">
    <div>
        <h1><i class="bi bi-trash me-2" style="color:var(--danger);"></i>Retirer le livre</h1>
        <p class="page-subtitle">#@Model.Id — @Model.Titre</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7 col-md-9">

        <!-- Avertissement -->
        <div class="admin-panel mb-4" style="border:1.5px solid rgba(239,68,68,.3);">
            <div class="admin-panel-header" style="background:rgba(239,68,68,.06);">
                <div class="admin-panel-title" style="color:var(--danger);">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Confirmation de suppression
                </div>
            </div>
            <div class="admin-panel-body">
                <p style="color:var(--text-secondary);font-size:.9rem;margin:0;">
                    Vous êtes sur le point de retirer définitivement
                    <strong>« @Model.Titre »</strong> de la bibliothèque.
                    Cette action est <strong>irréversible</strong>.
                </p>
            </div>
        </div>

        <!-- Récap avec couverture -->
        <div class="admin-panel mb-4">
            <div class="admin-panel-header">
                <div class="admin-panel-title">
                    <i class="bi bi-book"></i> Livre à retirer
                </div>
            </div>
            <div class="admin-panel-body">
                <div class="d-flex gap-4 align-items-start">
                    <!-- Miniature -->
                    <img src="/shared-assets/@Url.Content(Model.Image)"
                         alt="@Model.Titre"
                         onerror="this.src='/shared-assets/book-placeholder.png'"
                         style="width:80px;height:110px;object-fit:cover;border-radius:8px;box-shadow:0 4px 12px rgba(0,0,0,.15);flex-shrink:0;" />
                    <!-- Infos -->
                    <div class="flex-grow-1">
                        <h5 style="font-weight:700;color:var(--text-primary);margin-bottom:4px;">@Model.Titre</h5>
                        @if (!string.IsNullOrEmpty(Model.Sous_Titre))
                        {
                            <p class="text-muted-sm mb-2">@Model.Sous_Titre</p>
                        }
                        <table class="w-100" style="border-collapse:collapse;font-size:.85rem;">
                            <tr>
                                <td style="color:var(--text-muted);padding:4px 12px 4px 0;font-weight:600;width:130px;">Auteur</td>
                                <td style="color:var(--text-primary);">@Model.Auteur</td>
                            </tr>
                            @if (!string.IsNullOrEmpty(typeLivreText))
                            {
                                <tr>
                                    <td style="color:var(--text-muted);padding:4px 12px 4px 0;font-weight:600;">Type</td>
                                    <td><span class="badge-status pending">@typeLivreText</span></td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(Model.Saison))
                            {
                                <tr>
                                    <td style="color:var(--text-muted);padding:4px 12px 4px 0;font-weight:600;">Saison</td>
                                    <td style="color:var(--text-primary);">@Model.Saison</td>
                                </tr>
                            }
                            @if (Model.Date_Edition.HasValue)
                            {
                                <tr>
                                    <td style="color:var(--text-muted);padding:4px 12px 4px 0;font-weight:600;">Date d'édition</td>
                                    <td style="color:var(--text-primary);">@Model.Date_Edition!.Value.ToString("dd/MM/yyyy")</td>
                                </tr>
                            }
                            @if (!string.IsNullOrEmpty(Model.Description))
                            {
                                <tr>
                                    <td style="color:var(--text-muted);padding:4px 12px 4px 0;font-weight:600;vertical-align:top;">Description</td>
                                    <td style="color:var(--text-primary);line-height:1.5;">
                                        @(Model.Description.Length > 120
                                            ? Model.Description.Substring(0, 120) + "…"
                                            : Model.Description)
                                    </td>
                                </tr>
                            }
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Actions -->
        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />
            <div class="d-flex gap-3 justify-content-end">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="bi bi-x-lg"></i> Annuler
                </a>
                <button type="submit" class="btn"
                        style="background:var(--danger);border:none;color:#fff;box-shadow:0 4px 14px rgba(239,68,68,.35);border-radius:9px;padding:.5rem 1.2rem;font-weight:600;display:inline-flex;align-items:center;gap:6px;">
                    <i class="bi bi-trash-fill"></i> Confirmer la suppression
                </button>
            </div>
        </form>

    </div>
</div>
